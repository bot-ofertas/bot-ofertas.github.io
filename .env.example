# Copie para .env e preencha com seus valores reais
# NUNCA suba o arquivo .env para o GitHub.

# ── Telegram ──────────────────────────────────────────────
TOKEN_TELEGRAM=cole_aqui_o_token_do_BotFather
CANAL_GERAL=-100XXXXXXXXXXX

# ── Mercado Livre ─────────────────────────────────────────
ML_APP_ID=seu_app_id
ML_APP_SECRET=seu_app_secret
ML_ACCESS_TOKEN=
ML_AFFILIATE_TOOL_ID=47114387

# ── Amazon Associates Brasil (opcional) ───────────────────
# Crie sua conta em: https://associados.amazon.com.br/
# Formato: seu-apelido-20  (ex: meublog-20)
# Sem esta variável, o rastreador_amazon.py não roda.
AMAZON_AFFILIATE_TAG=

# ── IA — reescrita de títulos (opcional) ──────────────────
ANTHROPIC_API_KEY=

# ── Site e administração ──────────────────────────────────
# URL pública do site (usada nos botões do Telegram)
SITE_URL=https://bot-ofertas.github.io/
# IDs de chat autorizados a usar /status e /stats (separados por vírgula)
ADMIN_IDS=
